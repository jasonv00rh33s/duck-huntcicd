import random
import pygame
from src.config import SCREEN_WIDTH, SCREEN_HEIGHT, DIFFICULTY_SPEED

class Duck:
    DUCK_WIDTH = 90
    DUCK_HEIGHT = 90

def __init__(self, surface: pygame.Surface, difficulty: str = "normal"):
        self.surface = surface
        cfg = DIFFICULTY_SPEED[difficulty]
        self.base_speed = cfg["duck_step"]
        self._x = 0
        self._y = 0
        self._vx = 0
        self._vy = 0
        self._alive = True
        self._escaping = False
        self._frame_count = 0
        self.base_speed = cfg["duck_step"]
        self.flight_duration = cfg["flight_duration"]
        self.escape_speed = cfg["escape_speed"]

def spawn(self):
        self._x = random.randint(50, SCREEN_WIDTH - 50 - self.DUCK_WIDTH)
        self._y = SCREEN_HEIGHT - self.DUCK_HEIGHT
        self._vx = random.choice([-1, 1]) * random.uniform(0.6, 1.0) * self.base_speed
        self._vy = -random.uniform(0.8, 1.2) * self.base_speed
        self._alive = True
        self._escaping = False
        self._frame_count = 0

def update(self):
        self._x += self._vx
        self._y += self._vy

if not self._alive:
            return

        self._frame_count += 1

        if self._frame_count >= self.flight_duration and not self._escaping:
            self._escaping = True
            self._vx = 0
            self._vy = -self.base_speed * self.escape_speed
        if not self._escaping:
            if self._x <= 0:
                self._x = 0
                self._vx = abs(self._vx)
            elif self._x >= SCREEN_WIDTH - self.DUCK_WIDTH:
                self._x = SCREEN_WIDTH - self.DUCK_WIDTH
                self._vx = -abs(self._vx)

            if self._y <= 80:
                self._y = 80
                self._vy = abs(self._vy)
            elif self._y >= SCREEN_HEIGHT - self.DUCK_HEIGHT - 100:
                self._y = SCREEN_HEIGHT - self.DUCK_HEIGHT - 100
                self._vy = -abs(self._vy)

def kill(self):
        self._alive = False
        self._vx = 0
        self._vy = 6  

def is_hit(self, mouse_x: int, mouse_y: int) -> bool:
        return (
            self._alive and
            self._x <= mouse_x <= self._x + self.DUCK_WIDTH and
            self._y <= mouse_y <= self._y + self.DUCK_HEIGHT
        )

def is_escaped(self) -> bool:
        return self._alive and self._escaping and self._y < -self.DUCK_HEIGHT

def is_fallen(self) -> bool:
        return not self._alive and self._y > SCREEN_HEIGHT
